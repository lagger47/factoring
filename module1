End Sub

Sub CreateSummaryRepaymentSheet_All(wbMain As Workbook, wsRaw As Worksheet, srcRange As Range, controlDateFormatted As String, controlDateValue As Date, cumSplitDateFormatted As String, cumSplitDate As Date, uniqueID As String, colCustomerSimple As String, colClearingDate As String, colRepaymentDateYear As String, colFactoredYearDate As String, colAmount As String)
    On Error GoTo ErrHandler
    
    Dim wsPivot As Worksheet
    Dim pivotCount As Integer
    Dim currentRow As Long
    Dim lastRow As Long
    
    pivotCount = 0
    currentRow = 0
    
    On Error Resume Next
    Set wsPivot = wbMain.Sheets("Summary_of_Repayment")
    If Not wsPivot Is Nothing Then
        Application.DisplayAlerts = False
        wsPivot.Delete
        Application.DisplayAlerts = True
    End If
    On Error GoTo ErrHandler
    
    Set wsPivot = wbMain.Sheets.Add(After:=wbMain.Sheets(wbMain.Sheets.Count))
    wsPivot.Name = "Summary_of_Repayment"
    
    ' Pivot 1: All Others (Exclude Cummins, FCA, Ford)
    On Error Resume Next
    MsgBox "Creating Pivot 1: Customers not including Cummins, FCA, Ford", vbInformation
    lastRow = CreateSummaryPivot_All(wsPivot, srcRange, currentRow, 1, "Customers not including Cummins, FCA, Ford", "ExcludeCumminsFCAFord", "", controlDateFormatted, cumSplitDateFormatted, uniqueID, colCustomerSimple, colClearingDate, colRepaymentDateYear, colFactoredYearDate, colAmount)
    If Err.Number = 0 And lastRow > 0 Then
        pivotCount = pivotCount + 1
        MsgBox "Pivot 1 Created Successfully!", vbInformation
        currentRow = lastRow + 7
    Else
        MsgBox "Failed to create Pivot 1: " & Err.Description, vbCritical
        Err.Clear
    End If
    On Error GoTo ErrHandler
    
    ' Pivot 2: Cummins 2% till 10/03/2025
    On Error Resume Next
    MsgBox "Creating Pivot 2: Cummins 2% till 10/03/2025", vbInformation
    lastRow = CreateSummaryPivot_All(wsPivot, srcRange, currentRow, 2, "Cummins 2% till 10/03/2025", "Cummins", "Till", controlDateFormatted, cumSplitDateFormatted, uniqueID, colCustomerSimple, colClearingDate, colRepaymentDateYear, colFactoredYearDate, colAmount)
    If Err.Number = 0 And lastRow > 0 Then
        pivotCount = pivotCount + 1
        MsgBox "Pivot 2 Created Successfully!", vbInformation
