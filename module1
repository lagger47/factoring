Sub CreateFactoredPivot_All(wsPivot As Worksheet, srcRange As Range, rowOffset As Long, pivotIndex As Integer, pivotTitle As String, customerFilter As String, cumPeriod As String, controlDateFormatted As String, controlDateValue As Date, cumSplitDateFormatted As String, uniqueID As String, colCustomerSimple As String, colClearingDate As String, colRepaymentDateYear As String, colFactoredYearDate As String, colBusinessArea As String, colAmount As String, colRepaymentYear As String)
    On Error GoTo ErrHandler
    
    Dim ptCache As PivotCache
    Dim pt As PivotTable
    Dim pf As PivotField
    Dim pi As PivotItem
    Dim ptName As String
    Dim factoredYearPos As Integer
    
    ptName = "FactP" & CStr(pivotIndex) & "_" & uniqueID
    
    Set ptCache = wsPivot.Parent.PivotCaches.Create(xlDatabase, srcRange.Address(External:=True))
    Set pt = ptCache.CreatePivotTable(wsPivot.Range("A" & (rowOffset + 3)), ptName)
    
    wsPivot.Range("A" & (rowOffset + 1)).Value = "SUMMARY OF INVOICES PAID BACK TO M (" & pivotTitle & ")"
    wsPivot.Range("A" & (rowOffset + 1)).Font.Bold = True
    wsPivot.Range("A" & (rowOffset + 1)).Font.Size = 12
    wsPivot.Range("A" & (rowOffset + 1)).Interior.Color = RGB(200, 200, 200)
    
    With pt
        If colRepaymentYear <> "" Then
            Set pf = .PivotFields(colRepaymentYear)
            pf.Orientation = xlPageField
            pf.Position = 1
        End If
        
        factoredYearPos = 0
        If cumPeriod <> "" And colFactoredYearDate <> "" Then
            Set pf = .PivotFields(colFactoredYearDate)
            pf.Orientation = xlPageField
            pf.Position = 2
            factoredYearPos = 2
            FilterFactoredYearDate_All pf, cumSplitDateFormatted, cumPeriod
        End If
        
        Set pf = .PivotFields(colRepaymentDateYear)
        pf.Orientation = xlPageField
        If factoredYearPos > 0 Then pf.Position = 3 Else pf.Position = 2
        FilterRepaymentDate_NotFuture_All pf, controlDateFormatted
        
        Set pf = .PivotFields(colClearingDate)
        pf.Orientation = xlPageField
        If factoredYearPos > 0 Then pf.Position = 4 Else pf.Position = 3
        On Error Resume Next
        pf.CurrentPage = "(blank)"
        If Err.Number <> 0 Then
            Err.Clear
            For Each pi In pf.PivotItems
                If pi.Name <> "(blank)" And pi.Name <> "" Then pi.Visible = False
            Next pi
        End If
        On Error GoTo ErrHandler
        
        Set pf = .PivotFields(colCustomerSimple)
        pf.Orientation = xlPageField
        If factoredYearPos > 0 Then pf.Position = 5 Else pf.Position = 4
        
        If customerFilter = "ExcludeCumminsFCAFord" Then
            pf.EnableMultiplePageItems = True
            For Each pi In pf.PivotItems
                On Error Resume Next
                If pi.Name = "Cummins" Or pi.Name = "FCA" Or pi.Name = "Ford" Or pi.Name = "" Then
                    pi.Visible = False
                Else
                    pi.Visible = True
                End If
            Next pi
        Else
            On Error Resume Next
            pf.CurrentPage = customerFilter
            If Err.Number <> 0 Then
                Err.Clear
                pf.EnableMultiplePageItems = True
                For Each pi In pf.PivotItems
                    If pi.Name = customerFilter Then pi.Visible = True Else pi.Visible = False
                Next pi
            End If
        End If
        On Error GoTo ErrHandler
        
        Set pf = .PivotFields(colBusinessArea)
        pf.Orientation = xlRowField
        pf.Position = 1
        
        Set pf = .PivotFields(colAmount)
        pf.Orientation = xlDataField
        pf.Function = xlSum
        pf.NumberFormat = "#,##0.00"
        pf.Name = "Sum of Amount"
    End With
    
    Exit Sub
    
ErrHandler:
    MsgBox "Error creating Factored pivot '" & pivotTitle & "': " & Err.Description, vbCritical
End Sub

Sub FilterFactoredYearDate_All(pf As PivotField, cumSplitDateFormatted As String, cumPeriod As String)
    On Error Resume Next
    
    Dim pi As PivotItem
    Dim itemDateValue As String, itemYear As String, itemMonth As String, itemDay As String
    Dim itemDateCompare As String
    
    pf.EnableMultiplePageItems = True
    
    For Each pi In pf.PivotItems
        itemDateValue = pi.Name
        
        If Len(itemDateValue) >= 9 And InStr(itemDateValue, "-") > 0 Then
            itemYear = Left(itemDateValue, 4)
            itemMonth = Mid(itemDateValue, 6, 2)
            itemDay = Right(itemDateValue, 2)
            itemDateCompare = itemYear & itemMonth & itemDay
            
            If cumPeriod = "Till" Then
                If itemDateCompare <= cumSplitDateFormatted Then pi.Visible = True Else pi.Visible = False
            ElseIf cumPeriod = "After" Then
                If itemDateCompare > cumSplitDateFormatted Then pi.Visible = True Else pi.Visible = False
            End If
        Else
            pi.Visible = False
        End If
    Next pi
    
    On Error GoTo 0
End Sub

