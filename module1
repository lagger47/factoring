    CreateFactoredPivot_All wsPivot, srcRange, 120, 4, "FCA Only", "FCA", "", controlDateFormatted, controlDateValue, cumSplitDateFormatted, uniqueID, colCustomerSimple, colClearingDate, colRepaymentDateYear, colFactoredYearDate, colBusinessArea, colAmount, colRepaymentYear
