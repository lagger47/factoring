Option Explicit

Sub CreateAllRepaymentSheetsAndSummaryTables_NewRegion()
    On Error GoTo ErrHandler
    
    Dim rawFilePath As String
    Dim wbMain As Workbook
    Dim wbMacro As Workbook
    Dim wsRaw As Worksheet
    Dim srcRange As Range
    Dim controlDate As String
    Dim controlDateValue As Date
    Dim controlDateFormatted As String
    Dim colCustomerSimple As String
    Dim colClearingDate As String
    Dim colRepaymentDateYear As String
    Dim colFactoredYearDate As String
    Dim colBusinessArea As String
    Dim colAmount As String
    Dim colRepaymentYear As String
    Dim uniqueID As String
    Dim wsMapping As Worksheet
    
    Application.ScreenUpdating = False
    Application.DisplayAlerts = False
    
    Set wbMacro = ThisWorkbook
    
    On Error Resume Next
    Set wsMapping = wbMacro.Sheets("mapping")
    On Error GoTo ErrHandler
    
    If wsMapping Is Nothing Then
        MsgBox "Mapping sheet not found in the macro file!" & vbCrLf & _
               "Please ensure there is a sheet named 'mapping' in the macro file (.xlsm).", vbCritical
        GoTo Cleanup
    End If
    
    rawFilePath = Application.GetOpenFilename(FileFilter:="Excel Files (*.xls;*.xlsx;*.xlsm),*.xls;*.xlsx;*.xlsm", title:="Select Raw SAP Data File", MultiSelect:=False)
    
    If rawFilePath = "False" Then
        MsgBox "No file selected. Process cancelled.", vbExclamation
        GoTo Cleanup
    End If
    
    controlDate = InputBox("Enter Control Date (MM/DD/YYYY):" & vbCrLf & "This date determines:" & vbCrLf & "1. Future Due for Repayment Date" & vbCrLf & "2. New Month payments for Clearing Date" & vbCrLf & "3. Max Factored Date for DMAX", "Control Date", Format(Date, "mm/dd/yyyy"))
    
    If controlDate = "" Then
        controlDateValue = Date
    Else
        On Error Resume Next
        controlDateValue = CDate(controlDate)
        If Err.Number <> 0 Then
            MsgBox "Invalid date format. Using today's date.", vbExclamation
            controlDateValue = Date
            Err.Clear
        End If
        On Error GoTo ErrHandler
    End If
    
    controlDateFormatted = Format(controlDateValue, "yyyymmdd")
    uniqueID = Format(Now, "yyyymmddhhnnss")
    
    Set wbMain = Workbooks.Open(rawFilePath)
    Set wsRaw = wbMain.Sheets(1)
    
    FindColumnHeaders_All wsRaw, colCustomerSimple, colClearingDate, colRepaymentDateYear, colFactoredYearDate, colBusinessArea, colAmount, colRepaymentYear
    
    If colCustomerSimple = "" Or colBusinessArea = "" Or colAmount = "" Then
        MsgBox "Required columns not found in source data!" & vbCrLf & vbCrLf & _
               "Found:" & vbCrLf & _
               "Customer Simple: " & IIf(colCustomerSimple = "", "NOT FOUND", colCustomerSimple) & vbCrLf & _
               "Business Area: " & IIf(colBusinessArea = "", "NOT FOUND", colBusinessArea) & vbCrLf & _
               "Amount: " & IIf(colAmount = "", "NOT FOUND", colAmount) & vbCrLf & vbCrLf & _
               "Please check your source data has these columns.", vbCritical
        GoTo Cleanup
    End If
    
    MsgBox "Columns Found:" & vbCrLf & _
           "Customer Simple: " & colCustomerSimple & vbCrLf & _
           "Clearing Date: " & colClearingDate & vbCrLf & _
           "Repayment Date Year: " & colRepaymentDateYear & vbCrLf & _
           "Factored Year with Date: " & colFactoredYearDate & vbCrLf & _
           "Business Area: " & colBusinessArea & vbCrLf & _
           "Amount: " & colAmount & vbCrLf & _
           "Repayment Year: " & colRepaymentYear & vbCrLf & vbCrLf & _
           "Control Date: " & Format(controlDateValue, "mm/dd/yyyy"), vbInformation
    
    Set srcRange = wsRaw.Range("A1").CurrentRegion
    
    MsgBox "Creating FACTORED RECLASS sheet (4 pivot tables)...", vbInformation
    CreateFactoredReclassSheet_NewRegion wbMain, wsRaw, srcRange, controlDateFormatted, controlDateValue, uniqueID, colCustomerSimple, colClearingDate, colRepaymentDateYear, colFactoredYearDate, colBusinessArea, colAmount, colRepaymentYear
    
    MsgBox "Creating ACCRUED FACTOR PAY sheet (4 pivot tables)...", vbInformation
    CreateAccruedFactorPaySheet_NewRegion wbMain, wsRaw, srcRange, controlDateFormatted, controlDateValue, uniqueID, colCustomerSimple, colClearingDate, colRepaymentDateYear, colFactoredYearDate, colBusinessArea, colAmount, colRepaymentYear
    
    MsgBox "Creating SUMMARY OF REPAYMENT sheet (4 pivots in ONE sheet)...", vbInformation
    CreateSummaryRepaymentSheet_NewRegion wbMain, wsRaw, srcRange, controlDateFormatted, controlDateValue, uniqueID, colCustomerSimple, colClearingDate, colRepaymentDateYear, colFactoredYearDate, colAmount
    
    MsgBox "Creating summary tables for Factored_Reclass_All sheet...", vbInformation
    CreateSummaryTableForSheet_NewRegion wbMain.Sheets("Factored_Reclass_All"), wsMapping, Array(0.05, 0.25, 0.05, 0.3)
    
    MsgBox "Creating summary tables for Accrued_Factor_Pay_Info sheet...", vbInformation
    CreateSummaryTableForSheet_NewRegion wbMain.Sheets("Accrued_Factor_Pay_Info"), wsMapping, Array(0.05, 0.25, 0.05, 0.3)
    
    wbMain.Sheets("Factored_Reclass_All").Columns.AutoFit
    wbMain.Sheets("Accrued_Factor_Pay_Info").Columns.AutoFit
    wbMain.Sheets("Summary_of_Repayment").Columns.AutoFit
    
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    
    MsgBox "ALL SHEETS AND SUMMARY TABLES CREATED SUCCESSFULLY!" & vbCrLf & vbCrLf & _
           "Control Date: " & Format(controlDateValue, "mm/dd/yyyy") & vbCrLf & vbCrLf & _
           "SHEETS CREATED:" & vbCrLf & _
           "1. Factored_Reclass_All (4 pivots + 4 summary tables)" & vbCrLf & _
           "2. Accrued_Factor_Pay_Info (4 pivots + 4 summary tables)" & vbCrLf & _
           "3. Summary_of_Repayment (4 pivots)" & vbCrLf & vbCrLf & _
           "Customer Names Used:" & vbCrLf & _
           "DMAX LTD, DETROIT DIESEL CORP, DAIMLER TRUCKS N AMERICA," & vbCrLf & _
           "NISSAN MOTOR MANUFACTURING CORP. USA, NISSAN NORTH AMERICA," & vbCrLf & _
           "INTERNATIONAL INDUSTRIA AUTOMOTIVA, NAVISTAR INC," & vbCrLf & _
           "NAVISTAR DEFENSE LLC, Blue Diamond", vbInformation
    
    Exit Sub
    
ErrHandler:
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
    MsgBox "Error: " & Err.Description & vbCrLf & "Error Number: " & Err.Number, vbCritical
    Exit Sub

Cleanup:
    Application.ScreenUpdating = True
    Application.DisplayAlerts = True
End Sub

Sub FindColumnHeaders_All(ws As Worksheet, ByRef colCustomerSimple As String, ByRef colClearingDate As String, ByRef colRepaymentDateYear As String, ByRef colFactoredYearDate As String, ByRef colBusinessArea As String, ByRef colAmount As String, ByRef colRepaymentYear As String)
    Dim lastCol As Long, i As Long, cellValue As String
    
    lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column
    
    For i = 1 To lastCol
        cellValue = Trim(ws.Cells(1, i).Value)
        
        If InStr(1, cellValue, "CUSTOMER SIMPLE", vbTextCompare) > 0 Or InStr(1, cellValue, "CUSTOMER", vbTextCompare) > 0 Then colCustomerSimple = cellValue
        If InStr(1, cellValue, "Clearing date", vbTextCompare) > 0 Then colClearingDate = cellValue
        If InStr(1, cellValue, "Repayment Year with Date", vbTextCompare) > 0 Then colRepaymentDateYear = cellValue
        If InStr(1, cellValue, "Factored Year with Date", vbTextCompare) > 0 Then colFactoredYearDate = cellValue
        If InStr(1, cellValue, "Business Area", vbTextCompare) > 0 Then colBusinessArea = cellValue
        If InStr(1, cellValue, "Amount in doc. curr.", vbTextCompare) > 0 Then colAmount = cellValue
        If InStr(1, cellValue, "REPAYMENT YEAR", vbTextCompare) > 0 Or InStr(1, cellValue, "Repayment Year with Date", vbTextCompare) > 0 Then colRepaymentYear = cellValue
    Next i
End Sub

Sub CreateFactoredReclassSheet_NewRegion(wbMain As Workbook, wsRaw As Worksheet, srcRange As Range, controlDateFormatted As String, controlDateValue As Date, uniqueID As String, colCustomerSimple As String, colClearingDate As String, colRepaymentDateYear As String, colFactoredYearDate As String, colBusinessArea As String, colAmount As String, colRepaymentYear As String)
    On Error GoTo ErrHandler
    
    Dim wsPivot As Worksheet
    
    On Error Resume Next
    Set wsPivot = wbMain.Sheets("Factored_Reclass_All")
    If Not wsPivot Is Nothing Then
        Application.DisplayAlerts = False
        wsPivot.Delete
        Application.DisplayAlerts = True
    End If
    On Error GoTo ErrHandler
    
    Set wsPivot = wbMain.Sheets.Add(After:=wbMain.Sheets(wbMain.Sheets.Count))
    wsPivot.Name = "Factored_Reclass_All"
    
    CreateFactoredPivot_NewRegion wsPivot, srcRange, 0, 1, "SUMMARY OF INVOICES PAID BACK TO Wells Fargo BUT NOT YET PAID BY THE CUSTOMER (5%)", "ExcludeDMAX", "", controlDateFormatted, controlDateValue, uniqueID, colCustomerSimple, colClearingDate, colRepaymentDateYear, colFactoredYearDate, colBusinessArea, colAmount, colRepaymentYear
    CreateFactoredPivot_NewRegion wsPivot, srcRange, 40, 2, "Factored before 09/01/2024 (25%)", "DMAX", "Before09012024", controlDateFormatted, controlDateValue, uniqueID, colCustomerSimple, colClearingDate, colRepaymentDateYear, colFactoredYearDate, colBusinessArea, colAmount, colRepaymentYear
    CreateFactoredPivot_NewRegion wsPivot, srcRange, 80, 3, "Factored after 09/01/2024 to 6/12/2025 & after 7/31/2025 (5%)", "DMAX", "After09012024", controlDateFormatted, controlDateValue, uniqueID, colCustomerSimple, colClearingDate, colRepaymentDateYear, colFactoredYearDate, colBusinessArea, colAmount, colRepaymentYear
    CreateFactoredPivot_NewRegion wsPivot, srcRange, 120, 4, "Factored between 6/20/2025 to 7/31/2025 (30%)", "DMAX", "Between06202025_07312025", controlDateFormatted, controlDateValue, uniqueID, colCustomerSimple, colClearingDate, colRepaymentDateYear, colFactoredYearDate, colBusinessArea, colAmount, colRepaymentYear
    
    Exit Sub
    
ErrHandler:
    MsgBox "Error creating Factored sheet: " & Err.Description, vbCritical
End Sub

Sub CreateFactoredPivot_NewRegion(wsPivot As Worksheet, srcRange As Range, rowOffset As Long, pivotIndex As Integer, pivotTitle As String, customerFilter As String, dateFilter As String, controlDateFormatted As String, controlDateValue As Date, uniqueID As String, colCustomerSimple As String, colClearingDate As String, colRepaymentDateYear As String, colFactoredYearDate As String, colBusinessArea As String, colAmount As String, colRepaymentYear As String)
    On Error GoTo ErrHandler
    
    Dim ptCache As PivotCache
    Dim pt As PivotTable
    Dim pf As PivotField
    Dim pi As PivotItem
    Dim ptName As String
    
    ptName = "FactP" & CStr(pivotIndex) & "_" & uniqueID
    
    Set ptCache = wsPivot.Parent.PivotCaches.Create(xlDatabase, srcRange.Address(External:=True))
    Set pt = ptCache.CreatePivotTable(wsPivot.Range("A" & (rowOffset + 3)), ptName)
    
    wsPivot.Range("A" & (rowOffset + 1)).Value = pivotTitle
    wsPivot.Range("A" & (rowOffset + 1)).Font.Bold = True
    wsPivot.Range("A" & (rowOffset + 1)).Font.Size = 12
    wsPivot.Range("A" & (rowOffset + 1)).Interior.Color = RGB(200, 200, 200)
    
    With pt
        ' REPLAYMENT YEAR - Optional field
        If colRepaymentYear <> "" Then
            On Error Resume Next
            Set pf = .PivotFields(colRepaymentYear)
            If Not pf Is Nothing Then
                pf.Orientation = xlPageField
            End If
            Set pf = Nothing
            On Error GoTo ErrHandler
        End If
        
        ' FACTORED YEAR WITH DATE
        If colFactoredYearDate <> "" Then
            On Error Resume Next
            Set pf = .PivotFields(colFactoredYearDate)
            If Not pf Is Nothing Then
                pf.Orientation = xlPageField
                
                If dateFilter = "Before09012024" Then
                    FilterFactoredDate_Before pf, "20240901"
                ElseIf dateFilter = "After09012024" Then
                    FilterFactoredDate_After pf, "20240901", "20250612", "20250731"
                ElseIf dateFilter = "Between06202025_07312025" Then
                    FilterFactoredDate_Between pf, "20250620", "20250731"
                End If
            End If
            Set pf = Nothing
            On Error GoTo ErrHandler
        End If
        
        ' REPAYMENT DATE WITH YEAR
        On Error Resume Next
        Set pf = .PivotFields(colRepaymentDateYear)
        If Not pf Is Nothing Then
            pf.Orientation = xlPageField
            FilterRepaymentDate_NotFuture_All pf, controlDateFormatted
        End If
        Set pf = Nothing
        On Error GoTo ErrHandler
        
        ' CLEARING DATE
        On Error Resume Next
        Set pf = .PivotFields(colClearingDate)
        If Not pf Is Nothing Then
            pf.Orientation = xlPageField
            On Error Resume Next
            pf.CurrentPage = "(blank)"
            If Err.Number <> 0 Then
                Err.Clear
                For Each pi In pf.PivotItems
                    If pi.Name <> "(blank)" And pi.Name <> "" Then pi.Visible = False
                Next pi
            End If
        End If
        Set pf = Nothing
        On Error GoTo ErrHandler
        
        ' CUSTOMER SIMPLE
        On Error Resume Next
        Set pf = .PivotFields(colCustomerSimple)
        If Not pf Is Nothing Then
            pf.Orientation = xlPageField
            
            If customerFilter = "ExcludeDMAX" Then
                pf.EnableMultiplePageItems = True
                For Each pi In pf.PivotItems
                    On Error Resume Next
                    If InStr(pi.Name, "DMAX") > 0 Or pi.Name = "" Then
                        pi.Visible = False
                    Else
                        pi.Visible = True
                    End If
                Next pi
            Else
                On Error Resume Next
                pf.CurrentPage = "DMAX LTD"
                If Err.Number <> 0 Then
                    Err.Clear
                    pf.EnableMultiplePageItems = True
                    For Each pi In pf.PivotItems
                        If InStr(pi.Name, "DMAX") > 0 Then
                            pi.Visible = True
                        Else
                            pi.Visible = False
                        End If
                    Next pi
                End If
            End If
        End If
        Set pf = Nothing
        On Error GoTo ErrHandler
        
        ' BUSINESS AREA - ROWS
        On Error Resume Next
        Set pf = .PivotFields(colBusinessArea)
        If Not pf Is Nothing Then
            pf.Orientation = xlRowField
        End If
        Set pf = Nothing
        On Error GoTo ErrHandler
        
        ' AMOUNT - VALUES
        On Error Resume Next
        Set pf = .PivotFields(colAmount)
        If Not pf Is Nothing Then
            pf.Orientation = xlDataField
            pf.Function = xlSum
            pf.NumberFormat = "#,##0.00"
            pf.Name = "Sum of Amount"
        End If
        Set pf = Nothing
        On Error GoTo ErrHandler
    End With
    
    Exit Sub
    
ErrHandler:
    MsgBox "Error creating Factored pivot '" & pivotTitle & "': " & Err.Description & vbCrLf & _
           "Check if these columns exist in your source data:" & vbCrLf & _
           "Customer Simple: " & colCustomerSimple & vbCrLf & _
           "Clearing Date: " & colClearingDate & vbCrLf & _
           "Repayment Date Year: " & colRepaymentDateYear & vbCrLf & _
           "Business Area: " & colBusinessArea & vbCrLf & _
           "Amount: " & colAmount, vbCritical
End Sub

Sub FilterFactoredDate_Before(pf As PivotField, cutoffDate As String)
    On Error Resume Next
    
    Dim pi As PivotItem
    Dim itemDateValue As String, itemYear As String, itemMonth As String, itemDay As String
    Dim itemDateCompare As String
    
    pf.EnableMultiplePageItems = True
    
    For Each pi In pf.PivotItems
        itemDateValue = pi.Name
        
        If Len(itemDateValue) >= 9 And InStr(itemDateValue, "-") > 0 Then
            itemYear = Left(itemDateValue, 4)
            itemMonth = Mid(itemDateValue, 6, 2)
            itemDay = Right(itemDateValue, 2)
            itemDateCompare = itemYear & itemMonth & itemDay
            
            If itemDateCompare < cutoffDate Then
                pi.Visible = True
            Else
                pi.Visible = False
            End If
        Else
            pi.Visible = False
        End If
    Next pi
    
    On Error GoTo 0
End Sub

Sub FilterFactoredDate_After(pf As PivotField, startDate As String, endDate1 As String, endDate2 As String)
    On Error Resume Next
    
    Dim pi As PivotItem
    Dim itemDateValue As String, itemYear As String, itemMonth As String, itemDay As String
    Dim itemDateCompare As String
    
    pf.EnableMultiplePageItems = True
    
    For Each pi In pf.PivotItems
        itemDateValue = pi.Name
        
        If Len(itemDateValue) >= 9 And InStr(itemDateValue, "-") > 0 Then
            itemYear = Left(itemDateValue, 4)
            itemMonth = Mid(itemDateValue, 6, 2)
            itemDay = Right(itemDateValue, 2)
            itemDateCompare = itemYear & itemMonth & itemDay
            
            If (itemDateCompare > startDate And itemDateCompare <= endDate1) Or (itemDateCompare > endDate2) Then
                pi.Visible = True
            Else
                pi.Visible = False
            End If
        Else
            pi.Visible = False
        End If
    Next pi
    
    On Error GoTo 0
End Sub

Sub FilterFactoredDate_Between(pf As PivotField, startDate As String, endDate As String)
    On Error Resume Next
    
    Dim pi As PivotItem
    Dim itemDateValue As String, itemYear As String, itemMonth As String, itemDay As String
    Dim itemDateCompare As String
    
    pf.EnableMultiplePageItems = True
    
    For Each pi In pf.PivotItems
        itemDateValue = pi.Name
        
        If Len(itemDateValue) >= 9 And InStr(itemDateValue, "-") > 0 Then
            itemYear = Left(itemDateValue, 4)
            itemMonth = Mid(itemDateValue, 6, 2)
            itemDay = Right(itemDateValue, 2)
            itemDateCompare = itemYear & itemMonth & itemDay
            
            If itemDateCompare >= startDate And itemDateCompare <= endDate Then
                pi.Visible = True
            Else
                pi.Visible = False
            End If
        Else
            pi.Visible = False
        End If
    Next pi
    
    On Error GoTo 0
End Sub

Sub FilterRepaymentDate_NotFuture_All(pf As PivotField, controlDateFormatted As String)
    On Error Resume Next
    
    Dim pi As PivotItem
    Dim itemDateValue As String, itemYear As String, itemMonth As String, itemDay As String
    Dim itemDateCompare As String
    
    pf.EnableMultiplePageItems = True
    
    For Each pi In pf.PivotItems
        itemDateValue = pi.Name
        
        If Len(itemDateValue) >= 9 And InStr(itemDateValue, "-") > 0 Then
            itemYear = Left(itemDateValue, 4)
            itemMonth = Mid(itemDateValue, 6, 2)
            itemDay = Right(itemDateValue, 2)
            itemDateCompare = itemYear & itemMonth & itemDay
            
            If itemDateCompare > controlDateFormatted Then pi.Visible = False Else pi.Visible = True
        Else
            pi.Visible = True
        End If
    Next pi
    
    On Error GoTo 0
End Sub

Sub CreateAccruedFactorPaySheet_NewRegion(wbMain As Workbook, wsRaw As Worksheet, srcRange As Range, controlDateFormatted As String, controlDateValue As Date, uniqueID As String, colCustomerSimple As String, colClearingDate As String, colRepaymentDateYear As String, colFactoredYearDate As String, colBusinessArea As String, colAmount As String, colRepaymentYear As String)
