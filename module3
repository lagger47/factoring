Sub CreateAccruedPivot_NewRegion(wsPivot As Worksheet, srcRange As Range, rowOffset As Long, pivotIndex As Integer, pivotTitle As String, customerFilter As String, dateFilter As String, controlDateFormatted As String, controlDateValue As Date, uniqueID As String, colCustomerSimple As String, colClearingDate As String, colRepaymentDateYear As String, colFactoredYearDate As String, colBusinessArea As String, colAmount As String, colRepaymentYear As String)
    On Error GoTo ErrHandler
    
    Dim ptCache As PivotCache
    Dim pt As PivotTable
    Dim pf As PivotField
    Dim pi As PivotItem
    Dim ptName As String
    
