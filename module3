           "Check if these columns exist in your source data:" & vbCrLf & _
           "Customer Simple: " & colCustomerSimple & vbCrLf & _
           "Clearing Date: " & colClearingDate & vbCrLf & _
           "Repayment Date Year: " & colRepaymentDateYear & vbCrLf & _
           "Business Area: " & colBusinessArea & vbCrLf & _
           "Amount: " & colAmount, vbCritical
End Sub

Sub FilterClearingDate_Accrued_NewRegion(pf As PivotField, controlDateFormatted As String, controlDateValue As Date)
    On Error Resume Next
    
    Dim pi As PivotItem
    Dim itemDateValue As String, itemDateCompare As String
    Dim pivotItemDate As Date
    
    pf.EnableMultiplePageItems = True
    
    For Each pi In pf.PivotItems
        itemDateValue = pi.Name
        
        If pi.Name = "(blank)" Or pi.Name = "" Then
            pi.Visible = False
        ElseIf Len(itemDateValue) >= 9 And InStr(itemDateValue, "-") > 0 Then
            Dim itemYear As String, itemMonth As String, itemDay As String
            itemYear = Left(itemDateValue, 4)
            itemMonth = Mid(itemDateValue, 6, 2)
            itemDay = Right(itemDateValue, 2)
            itemDateCompare = itemYear & itemMonth & itemDay
            
            If itemDateCompare > controlDateFormatted Then pi.Visible = False Else pi.Visible = True
        ElseIf IsDate(itemDateValue) Then
            pivotItemDate = CDate(itemDateValue)
            If pivotItemDate > controlDateValue Then pi.Visible = False Else pi.Visible = True
        Else
            pi.Visible = True
        End If
    Next pi
    
    On Error GoTo 0
End Sub

