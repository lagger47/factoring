Function CreateSummaryPivot_NewRegion(wsPivot As Worksheet, srcRange As Range, rowOffset As Long, pivotIndex As Integer, pivotTitle As String, customerFilter As String, dateFilter As String, controlDateFormatted As String, uniqueID As String, colCustomerSimple As String, colClearingDate As String, colRepaymentDateYear As String, colFactoredYearDate As String, colAmount As String) As Long
    On Error GoTo ErrHandler
    
    Dim ptCache As PivotCache
    Dim pt As PivotTable
    Dim pf As PivotField
    Dim pi As PivotItem
    Dim ptName As String
    Dim lastRow As Long
    
    ptName = "SumPivot" & CStr(pivotIndex) & "_" & uniqueID
    
    MsgBox "Creating pivot table: " & ptName & " at row " & (rowOffset + 3), vbInformation
    
    Set ptCache = wsPivot.Parent.PivotCaches.Create(xlDatabase, srcRange.Address(External:=True))
    Set pt = ptCache.CreatePivotTable(wsPivot.Range("A" & (rowOffset + 3)), ptName)
    
    wsPivot.Range("A" & (rowOffset + 1)).Value = pivotTitle
    wsPivot.Range("A" & (rowOffset + 1)).Font.Bold = True
    wsPivot.Range("A" & (rowOffset + 1)).Font.Size = 12
    wsPivot.Range("A" & (rowOffset + 1)).Interior.Color = RGB(200, 230, 200)
    
    With pt
        On Error Resume Next
        Set pf = .PivotFields(colCustomerSimple)
        If Not pf Is Nothing Then
            pf.Orientation = xlPageField
            
            If customerFilter = "ExcludeDMAX" Then
                pf.EnableMultiplePageItems = True
                For Each pi In pf.PivotItems
                    On Error Resume Next
                    If InStr(pi.Name, "DMAX") > 0 Or pi.Name = "" Then
                        pi.Visible = False
                    Else
                        pi.Visible = True
                    End If
                Next pi
            Else
                On Error Resume Next
                pf.CurrentPage = "DMAX LTD"
                If Err.Number <> 0 Then
                    Err.Clear
                    pf.EnableMultiplePageItems = True
                    For Each pi In pf.PivotItems
                        If InStr(pi.Name, "DMAX") > 0 Then
                            pi.Visible = True
                        Else
                            pi.Visible = False
                        End If
                    Next pi
                End If
            End If
        End If
        Set pf = Nothing
        On Error GoTo ErrHandler
        
        If colFactoredYearDate <> "" And dateFilter <> "" Then
            On Error Resume Next
            Set pf = .PivotFields(colFactoredYearDate)
            If Not pf Is Nothing Then
                pf.Orientation = xlPageField
                
                If dateFilter = "Before09012024" Then
                    FilterFactoredDate_Before pf, "20240901"
                ElseIf dateFilter = "After09012024" Then
                    FilterFactoredDate_After pf, "20240901", "20250612", "20250731"
                ElseIf dateFilter = "Between06202025_07312025" Then
                    FilterFactoredDate_Between pf, "20250620", "20250731"
                End If
            End If
            Set pf = Nothing
            On Error GoTo ErrHandler
        End If
        
        On Error Resume Next
        Set pf = .PivotFields(colRepaymentDateYear)
        If Not pf Is Nothing Then
            pf.Orientation = xlRowField
        End If
        Set pf = Nothing
        On Error GoTo ErrHandler
        
        On Error Resume Next
        Set pf = .PivotFields(colClearingDate)
        If Not pf Is Nothing Then
            pf.Orientation = xlColumnField
            For Each pi In pf.PivotItems
                If pi.Name = "(blank)" Or pi.Name = "" Then
                    pi.Visible = False
                End If
            Next pi
        End If
        Set pf = Nothing
        On Error GoTo ErrHandler
        
        On Error Resume Next
        Set pf = .PivotFields(colAmount)
        If Not pf Is Nothing Then
            pf.Orientation = xlDataField
            pf.Function = xlSum
            pf.NumberFormat = "#,##0.00"
            pf.Name = "Sum of Amount"
        End If
        Set pf = Nothing
        On Error GoTo ErrHandler
    End With
    
    lastRow = pt.TableRange2.Rows.Count + rowOffset + 2
    
    MsgBox "Pivot " & ptName & " created successfully! Last row: " & lastRow, vbInformation
    
    CreateSummaryPivot_NewRegion = lastRow
    Exit Function
    
ErrHandler:
    MsgBox "Error creating Summary pivot '" & pivotTitle & "' (Pivot #" & pivotIndex & "): " & Err.Description & vbCrLf & _
           "Check if these columns exist in your source data:" & vbCrLf & _
           "Customer Simple: " & colCustomerSimple & vbCrLf & _
           "Clearing Date: " & colClearingDate & vbCrLf & _
           "Repayment Date Year: " & colRepaymentDateYear & vbCrLf & _
           "Amount: " & colAmount, vbCritical
    CreateSummaryPivot_NewRegion = -1
End Function

Sub CreateSummaryTableForSheet_NewRegion(ws As Worksheet, wsMapping As Worksheet, markupPercents As Variant)
    On Error GoTo ErrHandler
    
    Dim pt As PivotTable
    Dim pivotIndex As Integer
    Dim startRow As Long
    Dim lastRow As Long
    Dim summaryStartCol As Long
    Dim baValue As String
    Dim amountValue As Double
    Dim markupPercent As Double
    Dim markupValue As Double
    Dim totalValue As Double
    Dim mappingCode As String
    Dim jeCode As String
    Dim grandTotalAmount As Double
    Dim grandTotalMarkup As Double
    Dim grandTotalFinal As Double
    Dim i As Integer, j As Integer
    Dim tempPT As PivotTable
    Dim pivotArray() As PivotTable
    Dim pivotStartRows() As Long
    Dim pivotCount As Integer
    Dim mappingNotFound As Integer
    
    pivotCount = 0
    For Each pt In ws.PivotTables
        pivotCount = pivotCount + 1
    Next pt
    
    If pivotCount = 0 Then
        MsgBox "No pivot tables found in " & ws.Name, vbExclamation
        Exit Sub
    End If
    
    ReDim pivotArray(1 To pivotCount)
    ReDim pivotStartRows(1 To pivotCount)
    
    i = 0
    For Each pt In ws.PivotTables
        i = i + 1
        Set pivotArray(i) = pt
        pivotStartRows(i) = pt.TableRange1.Row
    Next pt
    
    For i = 1 To pivotCount - 1
        For j = i + 1 To pivotCount
            If pivotStartRows(i) > pivotStartRows(j) Then
                Dim tempRow As Long
                tempRow = pivotStartRows(i)
                pivotStartRows(i) = pivotStartRows(j)
                pivotStartRows(j) = tempRow
                
                Set tempPT = pivotArray(i)
                Set pivotArray(i) = pivotArray(j)
                Set pivotArray(j) = tempPT
            End If
        Next j
    Next i
    
    mappingNotFound = 0
    
    For pivotIndex = 1 To pivotCount
        If pivotIndex > 4 Then Exit For
        
        Set pt = pivotArray(pivotIndex)
        
        startRow = pt.TableRange1.Row
        lastRow = pt.TableRange2.Row + pt.TableRange2.Rows.Count - 1
        
        summaryStartCol = pt.TableRange2.Column + pt.TableRange2.Columns.Count + 2
        
        markupPercent = markupPercents(pivotIndex - 1)
        
        grandTotalAmount = 0
        grandTotalMarkup = 0
        grandTotalFinal = 0
        
        Dim dataRow As Long
        Dim summaryRow As Long
        summaryRow = startRow - 1
        
        For dataRow = startRow + 1 To lastRow - 1
            baValue = Trim(ws.Cells(dataRow, pt.TableRange2.Column).Value)
            
            Dim col As Long
            amountValue = 0
            
            For col = pt.TableRange2.Column + 1 To pt.TableRange2.Column + pt.TableRange2.Columns.Count - 1
                If IsNumeric(ws.Cells(dataRow, col).Value) Then
                    amountValue = ws.Cells(dataRow, col).Value
                    Exit For
                End If
            Next col
            
            If Left(baValue, 1) = "P" And amountValue <> 0 Then
                summaryRow = summaryRow + 1
                
                ws.Cells(summaryRow, summaryStartCol).Value = baValue
                
                ws.Cells(summaryRow, summaryStartCol + 1).Value = amountValue
                ws.Cells(summaryRow, summaryStartCol + 1).NumberFormat = "#,##0.00"
                
                markupValue = amountValue * markupPercent
                ws.Cells(summaryRow, summaryStartCol + 2).Value = markupValue
                ws.Cells(summaryRow, summaryStartCol + 2).NumberFormat = "#,##0.00"
                
                totalValue = amountValue - markupValue
                ws.Cells(summaryRow, summaryStartCol + 3).Value = totalValue
                ws.Cells(summaryRow, summaryStartCol + 3).NumberFormat = "#,##0.00"
                
                mappingCode = GetMappingCode(wsMapping, baValue)
                jeCode = GetJECode(wsMapping, baValue)
                
                If mappingCode = "" Then
                    mappingNotFound = mappingNotFound + 1
                    ws.Cells(summaryRow, summaryStartCol + 4).Value = baValue
                    ws.Cells(summaryRow, summaryStartCol + 5).Value = "NOT FOUND"
                    ws.Cells(summaryRow, summaryStartCol + 5).Interior.Color = RGB(255, 200, 200)
                    ws.Cells(summaryRow, summaryStartCol + 6).Value = "NOT FOUND"
                    ws.Cells(summaryRow, summaryStartCol + 6).Interior.Color = RGB(255, 200, 200)
                Else
                    ws.Cells(summaryRow, summaryStartCol + 4).Value = baValue
                    ws.Cells(summaryRow, summaryStartCol + 5).Value = mappingCode
                    ws.Cells(summaryRow, summaryStartCol + 6).Value = jeCode
                End If
                
                grandTotalAmount = grandTotalAmount + amountValue
                grandTotalMarkup = grandTotalMarkup + markupValue
                grandTotalFinal = grandTotalFinal + totalValue
            End If
        Next dataRow
        
        If summaryRow >= startRow Then
            summaryRow = summaryRow + 1
            
            ws.Cells(summaryRow, summaryStartCol).Value = "GRAND TOTAL"
            ws.Cells(summaryRow, summaryStartCol).Font.Bold = True
            ws.Cells(summaryRow, summaryStartCol).Interior.Color = RGB(200, 230, 200)
            
            ws.Cells(summaryRow, summaryStartCol + 1).Value = grandTotalAmount
            ws.Cells(summaryRow, summaryStartCol + 1).NumberFormat = "#,##0.00"
            ws.Cells(summaryRow, summaryStartCol + 1).Font.Bold = True
            ws.Cells(summaryRow, summaryStartCol + 1).Interior.Color = RGB(200, 230, 200)
            
            ws.Cells(summaryRow, summaryStartCol + 2).Value = grandTotalMarkup
            ws.Cells(summaryRow, summaryStartCol + 2).NumberFormat = "#,##0.00"
            ws.Cells(summaryRow, summaryStartCol + 2).Font.Bold = True
            ws.Cells(summaryRow, summaryStartCol + 2).Interior.Color = RGB(200, 230, 200)
            
            ws.Cells(summaryRow, summaryStartCol + 3).Value = grandTotalFinal
            ws.Cells(summaryRow, summaryStartCol + 3).NumberFormat = "#,##0.00"
            ws.Cells(summaryRow, summaryStartCol + 3).Font.Bold = True
            ws.Cells(summaryRow, summaryStartCol + 3).Interior.Color = RGB(200, 230, 200)
            
            ws.Range(ws.Cells(startRow, summaryStartCol), ws.Cells(summaryRow, summaryStartCol + 6)).BorderAround Weight:=xlMedium
            
            MsgBox "Pivot " & pivotIndex & " summary table created!" & vbCrLf & _
                   "Rows processed: " & (summaryRow - startRow) & vbCrLf & _
                   "Grand Total: " & Format(grandTotalFinal, "$#,##0.00"), vbInformation
        Else
            MsgBox "No data found in Pivot " & pivotIndex, vbExclamation
        End If
    Next pivotIndex
    
    If mappingNotFound > 0 Then
        MsgBox "Warning: " & mappingNotFound & " mapping codes not found in mapping sheet!", vbExclamation
    End If
    
    ws.Columns.AutoFit
    
    Exit Sub
    
ErrHandler:
    MsgBox "Error creating summary table for " & ws.Name & ": " & Err.Description & vbCrLf & "Error Number: " & Err.Number, vbCritical
End Sub

Function GetMappingCode(wsMapping As Worksheet, businessArea As String) As String
    On Error Resume Next
    
    Dim lastRow As Long
    Dim i As Long
    Dim baValue As String
    
    lastRow = wsMapping.Cells(wsMapping.Rows.Count, "A").End(xlUp).Row
    
    For i = 2 To lastRow
        baValue = Trim(wsMapping.Cells(i, 1).Value)
        If baValue = businessArea Then
            GetMappingCode = Trim(wsMapping.Cells(i, 5).Value)
            Exit Function
        End If
    Next i
    
    GetMappingCode = ""
    
    On Error GoTo 0
End Function

Function GetJECode(wsMapping As Worksheet, businessArea As String) As String
    On Error Resume Next
    
    Dim lastRow As Long
    Dim i As Long
    Dim baValue As String
    
    lastRow = wsMapping.Cells(wsMapping.Rows.Count, "A").End(xlUp).Row
    
    For i = 2 To lastRow
        baValue = Trim(wsMapping.Cells(i, 1).Value)
        If baValue = businessArea Then
            GetJECode = Trim(wsMapping.Cells(i, 3).Value)
            Exit Function
        End If
    Next i
    
    GetJECode = ""
    
    On Error GoTo 0
End Function

